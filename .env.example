# ClickHouse Cloud connection values. Use the hostname only (no https:// prefix).
CLICKHOUSE_HOST=your-service.region.provider.clickhouse.cloud
CLICKHOUSE_PORT=8443
CLICKHOUSE_USERNAME=default
CLICKHOUSE_PASSWORD=
CLICKHOUSE_DATABASE=cow_indexer
CLICKHOUSE_SECURE=true

COW_RPC_URL_MAINNET=
COW_RPC_URL_GNOSIS=
COW_RPC_URL_ARBITRUM=
COW_RPC_URL_BASE=
COW_RPC_URL_BNB=
COW_RPC_URL_POLYGON=
COW_RPC_URL_AVALANCHE=
COW_RPC_URL_LINEA=
COW_RPC_URL_INK=
COW_RPC_URL_PLASMA=
COW_RPC_URL_SEPOLIA=

# Select one configured chain or use "all" after the first-chain test.
COW_CHAIN=gnosis
COW_LOG_LEVEL=INFO
COW_METRICS_HOST=0.0.0.0
COW_METRICS_PORT=9090
COW_WORKER_ID=

# CoW API key (sent as X-API-Key; raises the rate allowance to ~30 RPS and avoids
# the public edge "Request blocked" 403s during historical enrichment). Leave blank
# to run unauthenticated at a much slower default rate.
COW_API_KEY=
# Enrichment request pacing (a GLOBAL budget shared across all chains, since every
# chain hits the same api.cow.fi host/key). Defaults: 0.1s (~10 RPS) with a key,
# 0.6s without. Under a key you can lower toward ~0.04 (~25 RPS, still under the ~30
# RPS ceiling). The client also backs off automatically toward
# COW_API_MAX_INTERVAL_SECONDS on 429/403.
COW_API_INTERVAL_SECONDS=
COW_API_MAX_INTERVAL_SECONDS=5.0
COW_ENRICH_CONCURRENCY=6
COW_MAX_ATTEMPTS=6
